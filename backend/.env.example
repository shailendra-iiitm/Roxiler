db_host=localhost
db_port=3306
db_user=root
db_password=your_db_password
db_database=store_rating_app

# Optional aliases supported by the backend (cloud-friendly names)
# DB_HOST=
# DB_PORT=
# DB_USER=
# DB_PASSWORD=
# DB_DATABASE=
# MYSQLHOST=
# MYSQLPORT=
# MYSQLUSER=
# MYSQLPASSWORD=
# MYSQLDATABASE=

# Optional single-string format
# DATABASE_URL=mysql://user:password@host:3306/database

# Set true if your provider requires TLS/SSL
# DB_SSL=true

# Recommended for production
JWT_SECRET=replace_with_strong_secret
PORT=5000
CORS_ORIGIN=http://localhost:5173
